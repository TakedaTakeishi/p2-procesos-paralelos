% ==========================================
% REFERENCIAS BIBLIOGRÁFICAS
% ==========================================
%
% Agrega aquí tus referencias en formato BibTeX.
% Luego cítalas en el texto con \cite{clave} o \textcite{clave}.
%
% TIPOS DE REFERENCIA MÁS COMUNES:
%
%   @book{}        → Libro
%   @article{}     → Artículo de revista
%   @inproceedings → Artículo de conferencia
%   @misc{}        → Páginas web, documentación, etc.
%   @thesis{}      → Tesis (mastersthesis, phdthesis)
%
% TIP: Puedes obtener entradas BibTeX automáticas desde:
%      - Google Scholar → botón "Citar" → BibTeX
%      - DOI → https://doi2bib.org
%
% TIP: La clave (ej: knuth1997) es lo que usas en \cite{}.
%      Usa un formato consistente: apellido+año
%
% ==========================================

% --- EJEMPLOS (descomenta y adapta) ---

% @book{knuth1997,
%     author    = {Donald E. Knuth},
%     title     = {The Art of Computer Programming},
%     publisher = {Addison-Wesley},
%     year      = {1997},
%     volume    = {1},
% }

% @article{turing1950,
%     author  = {Alan M. Turing},
%     title   = {Computing Machinery and Intelligence},
%     journal = {Mind},
%     year    = {1950},
%     volume  = {59},
%     number  = {236},
%     pages   = {433--460},
% }

% @misc{python_docs,
%     author = {{Python Software Foundation}},
%     title  = {Python 3 Documentation},
%     year   = {2024},
%     url    = {https://docs.python.org/3/},
%     note   = {Consultado: 15 de febrero de 2026},
% }


